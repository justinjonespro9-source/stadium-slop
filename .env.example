# --- Database (required for Prisma) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stadium_slop?schema=public"

# --- Public site URL (Auth.js + OG absolute URLs) ---
# Local dev: http://127.0.0.1:3000 or http://localhost:3000
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3000"
# Auth.js v5 also reads AUTH_URL (or NEXTAUTH_URL) — should match your dev/prod origin
AUTH_URL="http://127.0.0.1:3000"
# NEXTAUTH_URL="http://127.0.0.1:3000"

# --- Google OAuth (contributor + admin sign-in) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized JavaScript origins (local): http://127.0.0.1:3000
# Authorized redirect URI (local — must match AUTH_URL host):
#   http://127.0.0.1:3000/api/auth/callback/google
# Production (replace host):
#   https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional Auth.js aliases (same values): AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET

# --- Auth.js session secret (required) ---
# Generate: openssl rand -base64 32
AUTH_SECRET=""
# NEXTAUTH_SECRET=""  # legacy alias, still supported

# --- Admin bootstrap ---
# ADMIN_EMAILS: comma-separated — new Google sign-ups get User.role ADMIN on first create only.
# Existing users: npm run make-admin -- email@example.com (after one /login sign-in).
ADMIN_EMAILS="hello@stadiumslop.com"

# --- Development-only shortcuts (never enable in production) ---
# ENABLE_MOCK_USER_AUTH=true   # optional mock fan cookie on /login (not Google)
# npm run seed:demo-scorecards — 3 Slop Scorecards on target-field / la-madre-street-elote
# ENABLE_DEMO_SCORECARDS=true  # required to run seed:demo-scorecards in production only
# DEMO_SCORECARD_VENUE_SLUG=target-field
# DEMO_SCORECARD_FOOD_SLUG=la-madre-street-elote

# --- Cloudinary (server-side only — fan photo uploads) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: cap how long the home page waits on Postgres before using sample venues (default 4000).
# STADIUM_SLOP_DB_QUERY_TIMEOUT_MS=4000
