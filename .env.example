# --- Database (required for Prisma; use a real URL in production) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stadium_slop?schema=public"

# --- Cloudinary (server-side only — required for fan photo uploads to work) ---
# Leave empty locally if you are not testing uploads; reviews still save without photos.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# No Stripe, OAuth client secrets, or email provider keys in this MVP.

# Optional: cap how long the home page waits on Postgres before using sample venues (default 4000).
# STADIUM_SLOP_DB_QUERY_TIMEOUT_MS=4000
